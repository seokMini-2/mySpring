### 잘 살아있나 확인
GET localhost:8080/hello

### 사용자 생성
POST localhost:8080/users
Content-Type: application/json

{
  "username": "seokmin"
}

### 사용자 목록 보기
GET localhost:8080/users

### 같은 username으로 중복 테스트
POST localhost:8080/users
Content-Type: application/json

{
  "username": "seokmin"
}

### 사용자 추가하기
POST localhost:8080/users
Content-Type: application/json

{
  "username": "hana"
}

### 같은 username으로 중복 테스트(에러 코드 500 -> 400)
POST localhost:8080/users
Content-Type: application/json

{
  "username": "seokmin"
}

### post 정상 작동 확인을 위한 회원 writer1 생성
POST localhost:8080/users
Content-Type: application/json

{
  "username": "writer1"
}

### 생성 확인 id=3
GET localhost:8080/users

### 게시글 작성
POST localhost:8080/posts
Content-Type: application/json

{"userId": 2,
  "title": "페이지 확인을 위한...",
  "content": "몇번째 게시물이 되려나"
}

### 게시글 목록 조회
GET localhost:8080/posts

### 게시글 상세 조회
GET localhost:8080/posts/3

### 게시글 삭제
DELETE localhost:8080/posts/1

### 게시글 수정
PUT localhost:8080/posts/3
Content-Type: application/json

{
  "title": "바보입니다",
  "content": "제 이름은 코난, 명탐정이죠"
}

### 댓글 생성(게시글 하위)
POST localhost:8080/posts/4/comments
Content-Type: application/json

{"postId": 4,
"userId": 1,
  "content": "하위 리소스로 만든 댓글입니다."
}

### 댓글 삭제
DELETE localhost:8080/comments/3

###게시글 4번의 댓글 조회(게시글 하위)
GET localhost:8080/posts/4/comments

### 게시글 페이징 조회(최신순 5개)
GET localhost:8080/posts?page=0&size=20&sort=id,desc

### 댓글 페이징 조회 (최신순 10개)
GET http://localhost:8080/posts/4/comments?page=0&size=10&sort=id,desc

### DTO Projection을 사용하여 게시글 목록 조회
GET http://localhost:8080/posts?page=0&size=10&sort=id,desc

### 3번 게시물 수정하기.
PUT localhost:8080/posts/3
Content-Type: application/json

{
  "userId": 1,
  "title": "수정된 제목",
  "content": "수정된 내용입니다."
}

### 3번 게시물 수정 실패
PUT localhost:8080/posts/3
Content-Type: application/json

{
  "userId": 99,
  "title": "해킹시도",
  "content": "드루와라"
}

### 4번 댓글 삭제 성공
DELETE localhost:8080/comments/4?userId=1

### 5번 댓글 삭제 실패
DELETE localhost:8080/comments/5?userId=99

### 회원가입
POST localhost:8080/users
Content-Type: application/json

{
  "username": "LeeSeokMin",
  "password": "1234"
}